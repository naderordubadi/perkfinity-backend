{
  "name": "perkfinity-backend",
  "version": "1.0.0",
  "description": "Perkfinity Backend",
  "main": "src/server.ts",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit && tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^8.3.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^7.2.1",
    "@fastify/rate-limit": "^8.0.3",
    "@fastify/swagger": "^8.9.0",
    "@fastify/swagger-ui": "^1.9.0",
    "@prisma/client": "^5.2.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "fastify": "^4.22.0",
    "fastify-plugin": "^4.5.1",
    "fastify-type-provider-zod": "^2.0.0",
    "node-cron": "^3.0.2",
    "pino": "^8.15.0",
    "pino-pretty": "^10.2.0",
    "prisma": "^5.2.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.2",
    "zod-to-json-schema": "^3.21.4",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.5.9",
    "@types/uuid": "^9.0.3",
    "@types/node-cron": "^3.0.8",
    "@vercel/node": "^3.0.0",
    "ts-node": "^10.9.1",
    "tsx": "^3.12.7",
    "typescript": "^5.2.2",
    "vitest": "^0.34.3"
  }
}